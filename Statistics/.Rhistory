for (i in 1:length(principles)) {
p = principles[i]
#print(paste("Principle ", p))
cat("\n\n### Principle ", p, "\n\n")
data_final <- data_filtered %>%
filter(principle == p)
count <- data_final %>%
group_by(category) %>%
summarise(goal_count = n_distinct(goal), .groups = "drop")
partial <- categories %>%
select(category) %>%
left_join(count, by = "category") %>%
mutate(goal_count = ifelse(is.na(goal_count), 0, goal_count))
partial$category <- factor(partial$category, levels = categories$category)
picturePrinciple <- ggplot(partial, aes(x = category, y = goal_count, fill = category))+
geom_bar(stat="identity", position=position_dodge(width=0.9), width=0.9, show.legend = FALSE)+
geom_text(aes(label=goal_count),position=position_dodge(width=0.9), vjust=-0.5, hjust=0.5, color="black", size=3.5)+
labs(title = "", x = "Normative / Law", y = "Number of goals")+
scale_fill_manual(values = palette)+
scale_y_continuous(breaks = scales::pretty_breaks())+
expand_limits(y = max(partial$goal_count) + 0)
print(picturePrinciple)
}
