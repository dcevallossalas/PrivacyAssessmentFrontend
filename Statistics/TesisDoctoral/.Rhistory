axis.title.y = element_text(size = 18),
axis.text.x = element_text(size = 18),
axis.text.y = element_text(size = 18),
legend.title  = element_text(size = 18
legend.text  = element_text(size = 18)
library(sur)
library(ggplot2)
library(ggpubr)
library(readxl)
library(viridis)
library(dplyr)
library(tidyr)
library(readr)
library(colorspace)
categories <- read_csv("E:/Doctorado/PrivacyAssessmentFrontend/Statistics/categories_hallucinations_train.csv", show_col_types = FALSE)
n <- n_distinct(categories$category)
if (n <= 24) {
palette <- c(
"#FF0000", # rojo
"#0000FF", # azul
"#00FF00", # verde
"#8B4513", # café/marrón
"#000000", # negro
"#FFA500", # naranja
"#800080", # morado
"#00FFFF", # cian
"#FFC0CB", # rosa
"#808080", # gris
"#008080", # teal
"#FF1493", # deep pink
"#4B0082", # índigo
"#40E0D0", # turquesa
"#FF4500", # naranja rojizo
"#6A5ACD", # slate blue
"#2E8B57", # verde mar
"#00CED1", # dark turquoise
"#D2691E", # chocolate
"#BA55D3", # medium orchid
"#4682B4", # steel blue
"#9ACD32", # amarillo verdoso (evita amarillo puro)
"#CD5C5C", # indian red
"#20B2AA"  # light sea green
)
palette <- palette[1:n]
} else {
palette <- viridis(n, alpha= 1, begin = 0.1, end = 0.9, direction = -1, option="viridis")
}
data <- read_csv("E:/Doctorado/PrivacyAssessmentFrontend/Statistics/logprobs_hallucinations_train.csv", show_col_types = FALSE)
ct <- seq(from = 0, to = 1, by = 0.05)
df <- data.frame()
for (umbral in ct) {
data_filtered <- data %>%
filter(exp(logprob) >= umbral & logprob > -10)
count <- data_filtered %>%
group_by(category) %>%
summarise(subclause_count = n_distinct(goal), .groups = "drop")
partial <- categories %>%
select(category) %>%
left_join(count, by = "category") %>%
mutate(subclause_count = ifelse(is.na(subclause_count), 0, subclause_count),
ct = umbral)
df <- bind_rows(df, partial)
df$category <- factor(df$category, levels = categories$category)
}
picturesubclauses <- ggplot(df, aes(x = ct, y = subclause_count, color = category)) +
geom_line() +
geom_point() +
scale_x_continuous(breaks = seq(0, 1, by = 0.1),
labels = scales::number_format(accuracy = 0.01)) +
scale_y_continuous(breaks = seq(0, max(df$subclause_count), by = 1),
labels = scales::number_format(accuracy = 1)) +
scale_color_manual(values = palette)+
labs(
x = "Confidence threshold",
y = "Number of hallucinations",
color = "Privacy Legal Framework"
) +
theme_light()+
theme(
axis.title.x = element_text(size = 18),
axis.title.y = element_text(size = 18),
axis.text.x = element_text(size = 18),
axis.text.y = element_text(size = 18),
legend.title  = element_text(size = 18),
legend.text  = element_text(size = 18)
)
picturesubclauses
picturesubclauses
library(readxl)
library(ggplot2)
library(dplyr)
pc <- read_excel("E:/Doctorado/PrivProtComplete/Times.xlsx",
sheet = "PhysicalControl")
pd <- read_excel("E:/Doctorado/PrivProtComplete/Times.xlsx",
sheet = "PhysicalData")
vc <- read_excel("E:/Doctorado/PrivProtComplete/Times.xlsx",
sheet = "VirtualControl")
vd <- read_excel("E:/Doctorado/PrivProtComplete/Times.xlsx",
sheet = "VirtualData")
# Physical Control
# Colors
colors <- rainbow(10)
color1 <- colors[1]
color2 <- colors[7]
n <- length(pc$Trial)
data <- data.frame(
Trial = c(rep(pc$Trial,2)),
RoundTrip = c(pc$PrivProt, pc$HTTP),
Protocol = factor(c(rep("PrivProt", n), rep("HTTP", n)), levels = c("PrivProt", "HTTP"))
)
std = sd(pc$HTTP)
data_privprot <- data %>% filter(Protocol == "HTTP")
std1 = sd(pc$PrivProt)
data_privprot1 <- data %>% filter(Protocol == "PrivProt")
p1 <- ggplot(data, aes(x=Trial, y=RoundTrip, group=Protocol)) +
geom_line(aes(color=Protocol))+
geom_point(aes(color=Protocol, shape=Protocol))+
geom_ribbon(data = data_privprot,
aes(ymin = RoundTrip - std, ymax = RoundTrip + std),
fill = "lightcyan3", alpha = 0.5) +
geom_ribbon(data = data_privprot1,
aes(ymin = RoundTrip - std1, ymax = RoundTrip + std1),
fill = "coral", alpha = 0.5) +
scale_color_manual(values = c(color1, color2)) +
scale_shape_manual(values = c(17, 16)) +
scale_x_continuous(limits=c(1,50),breaks = seq(1, 50, by = 1)) +
labs(y = "RTT (ms)")+
theme(
axis.text = element_text(size = 13),
axis.title = element_text(size = 16),
legend.text = element_text(size = 15),
legend.title = element_text(size = 16)
)
# Physical Data
n <- length(pd$Trial)
data <- data.frame(
Trial = c(rep(pd$Trial,2)),
RoundTrip = c(pd$PrivProt, pd$HTTP),
Protocol = factor(c(rep("PrivProt", n), rep("HTTP", n)), levels = c("PrivProt", "HTTP"))
)
std = sd(pd$HTTP)
data_privprot <- data %>% filter(Protocol == "HTTP")
std1 = sd(pd$PrivProt)
data_privprot1 <- data %>% filter(Protocol == "PrivProt")
p2 <- ggplot(data, aes(x=Trial, y=RoundTrip, group=Protocol)) +
geom_line(aes(color=Protocol))+
geom_point(aes(color=Protocol, shape=Protocol))+
geom_ribbon(data = data_privprot,
aes(ymin = RoundTrip - std, ymax = RoundTrip + std),
fill = "lightcyan3", alpha = 0.5) +
geom_ribbon(data = data_privprot1,
aes(ymin = RoundTrip - std1, ymax = RoundTrip + std1),
fill = "coral", alpha = 0.5) +
scale_color_manual(values = c(color1, color2)) +
scale_shape_manual(values = c(17, 16)) +
scale_x_continuous(limits=c(1,50),breaks = seq(1, 50, by = 1)) +
labs(y = "RTT (ms)")+
theme(
axis.text = element_text(size = 13),
axis.title = element_text(size = 16),
legend.text = element_text(size = 15),
legend.title = element_text(size = 16)
)
# Virtual Control
n <- length(vc$Trial)
data <- data.frame(
Trial = c(rep(vc$Trial,2)),
RoundTrip = c(vc$PrivProt, vc$HTTP),
Protocol = factor(c(rep("PrivProt", n), rep("HTTP", n)), levels = c("PrivProt", "HTTP"))
)
std = sd(vc$HTTP)
data_privprot <- data %>% filter(Protocol == "HTTP")
std1 = sd(vc$PrivProt)
data_privprot1 <- data %>% filter(Protocol == "PrivProt")
p3 <- ggplot(data, aes(x=Trial, y=RoundTrip, group=Protocol)) +
geom_line(aes(color=Protocol), linetype = "dashed")+
geom_point(aes(color=Protocol, shape=Protocol))+
geom_ribbon(data = data_privprot,
aes(ymin = RoundTrip - std, ymax = RoundTrip + std),
fill = "lightcyan3", alpha = 0.5) +
geom_ribbon(data = data_privprot1,
aes(ymin = RoundTrip - std1, ymax = RoundTrip + std1),
fill = "coral", alpha = 0.5) +
scale_color_manual(values = c(color1, color2)) +
scale_shape_manual(values = c(17, 16)) +
scale_x_continuous(limits=c(1,50),breaks = seq(1, 50, by = 1)) +
labs(y = "RTT (ms)")+
theme(
axis.text = element_text(size = 13),
axis.title = element_text(size = 16),
legend.text = element_text(size = 15),
legend.title = element_text(size = 16)
)
# Virtual Data
n <- length(vd$Trial)
data <- data.frame(
Trial = c(rep(vd$Trial,2)),
RoundTrip = c(vd$PrivProt, vd$HTTP),
Protocol = factor(c(rep("PrivProt", n), rep("HTTP", n)), levels = c("PrivProt", "HTTP"))
)
std = sd(vd$HTTP)
data_privprot <- data %>% filter(Protocol == "HTTP")
std1 = sd(vd$PrivProt)
data_privprot1 <- data %>% filter(Protocol == "PrivProt")
p4 <- ggplot(data, aes(x=Trial, y=RoundTrip, group=Protocol)) +
geom_line(aes(color=Protocol), linetype = "dashed")+
geom_point(aes(color=Protocol, shape=Protocol))+
geom_ribbon(data = data_privprot,
aes(ymin = RoundTrip - std, ymax = RoundTrip + std),
fill = "lightcyan3", alpha = 0.5) +
geom_ribbon(data = data_privprot1,
aes(ymin = RoundTrip - std1, ymax = RoundTrip + std1),
fill = "coral", alpha = 0.5) +
scale_color_manual(values = c(color1, color2)) +
scale_shape_manual(values = c(17, 16)) +
scale_x_continuous(limits=c(1,50),breaks = seq(1, 50, by = 1)) +
labs(y = "RTT (ms)")+
theme(
axis.text = element_text(size = 13),
axis.title = element_text(size = 16),
legend.text = element_text(size = 15),
legend.title = element_text(size = 16)
)
# Physical device
n <- length(pc$Trial)
data <- data.frame(
Type = c(rep("Control", n), rep("Data", n), rep("Control", n), rep("Data", n)),
RoundTrip = c(pc$PrivProt, pd$PrivProt, pc$HTTP, pd$HTTP),
Protocol = factor(c(rep("PrivProt", n*2), rep("HTTP", n*2)), levels = c("PrivProt", "HTTP"))
)
pos <- position_dodge(width = 0.75)
p5 <- ggplot(data, aes(x = Type, y = RoundTrip, fill = Protocol)) +
stat_boxplot(aes(group = interaction(Type, Protocol)),
geom = "errorbar",
width = 0.2,
position = pos) +
geom_boxplot(width = 0.6, fatten = 1, position = pos) +
scale_fill_manual(values = c(color1, color2)) +
scale_y_continuous(limits=c(0,90),breaks = seq(0, 90, by = 10)) +
labs(x = "Transmission type", y = "RTT (ms)")
# Virtual device
n <- length(pc$Trial)
data <- data.frame(
Type = c(rep("Control", n), rep("Data", n), rep("Control", n), rep("Data", n)),
RoundTrip = c(vc$PrivProt, vd$PrivProt, vc$HTTP, vd$HTTP),
Protocol = factor(c(rep("PrivProt", n*2), rep("HTTP", n*2)), levels = c("PrivProt", "HTTP"))
)
pos <- position_dodge(width = 0.75)
p6 <- ggplot(data, aes(x = Type, y = RoundTrip, fill = Protocol)) +
stat_boxplot(aes(group = interaction(Type, Protocol)),
geom = "errorbar",
width = 0.2,
position = pos, linetype = "dashed") +
geom_boxplot(width = 0.6, fatten = 1, position = pos, linetype = "dashed") +
scale_fill_manual(values = c(color1, color2)) +
scale_y_continuous(limits=c(0,35),breaks = seq(0, 35, by = 5)) +
labs(x = "Transmission type", y = "RTT (ms)")
# Physical Control Hypothesis Test
options(digits = 22)
for (i in 1:4) {
print("---------------------------------------------------------------")
scenario = switch(i,"Physical-Control","Physical-Data","Virtual-Control","Virtual-Data")
print(scenario)
print("---------------------------------------------------------------")
privprot = switch(i,pc$PrivProt,pd$PrivProt,vc$PrivProt,vd$PrivProt)
print("PrivProt")
m1 = mean(privprot)
options(digits = 22)
print(m1)
m11 = median(privprot)
print(m11)
sd1 = sd(privprot)
print(sd1)
http = switch(i,pc$HTTP,pd$HTTP,vc$HTTP,vd$HTTP)
print("HTTP")
m2 = mean(http)
print(m2)
m22 = median(http)
print(m22)
sd2 = sd(http)
print(sd2)
print(fligner.test(x=list(privprot,http)))
if (m11 < m22) {
print(wilcox.test(privprot,http,alternative="less"))
} else {
print(wilcox.test(http,privprot,alternative="less"))
}
}
p1
p2
p3
p4
p5
p6
